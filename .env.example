DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require&channel_binding=require

# LLM — local dev: http://localhost:11434/v1
#         production: http://<EC2-PUBLIC-IP>:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:14b
# Set to true in production to disable Groq/OpenRouter fallbacks
LLM_NO_FALLBACK=false

TINYFISH_API_KEY=sk-tinyfish-...
OPENROUTER_API_KEY=sk-or-v1-...
RESEND_API_KEY=re_...
RESEND_FROM=Polaris <polaris@yourdomain.com>
ADMIN_EMAIL=admin@example.com
AGENT_SECRET=change-me
NEXT_PUBLIC_AGENT_SECRET=change-me
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app
